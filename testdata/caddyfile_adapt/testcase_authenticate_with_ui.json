{
    "apps": {
        "http": {
            "servers": {
                "srv0": {
                    "listen": [
                        ":8443"
                    ],
                    "routes": [
                        {
                            "handle": [
                                {
                                    "handler": "static_response",
                                    "headers": {
                                        "Location": [
                                            "https://{http.request.hostport}/auth/"
                                        ]
                                    },
                                    "status_code": 302
                                }
                            ]
                        },
                        {
                            "match": [
                                {
                                    "path": [
                                        "/auth*"
                                    ]
                                }
                            ],
                            "handle": [
                                {
                                    "handler": "subroute",
                                    "routes": [
                                        {
                                            "handle": [
                                                {
                                                    "handler": "authenticator",
                                                    "portal_name": "myportal",
                                                    "route_matcher": "*"
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                }
            }
        },
        "security": {
            "config": {
                "authentication_portals": [
                    {
                        "name": "myportal",
                        "ui": {
                            "templates": {
                                "login": "{env.APP_FILES_DIR}/ui/login.template",
                                "portal": "{env.APP_FILES_DIR}ui/portal.template",
                                "sandbox": "{env.APP_FILES_DIR}ui/sandbox.template",
                                "whoami": "{env.APP_FILES_DIR}ui/whoami.template"
                            },
                            "meta_title": "{env.APP_COMPANY_NAME} Authentication Portal",
                            "meta_description": "Authentication Portal for {env.APP_COMPANY_NAME} Users.",
                            "meta_author": "{env.APP_COMPANY_NAME}",
                            "private_links": [
                                {
                                    "link": "https://apps.{env.GLOBAL_APP_DOMAIN}:8443/",
                                    "title": "My Apps",
                                    "icon_name": "las la-sitemap",
                                    "icon_enabled": true
                                }
                            ],
                            "static_assets": [
                                {
                                    "path": "assets/{env.APP_FILES_DIR}/images/banner.jpg",
                                    "fs_path": "ui/banner.jpg",
                                    "content_type": "images/jpg"
                                },
                                {
                                    "path": "assets/{env.APP_FILES_DIR}/images/logo.png",
                                    "fs_path": "ui/logo.png",
                                    "content_type": "images/png"
                                },
                                {
                                    "path": "assets/{env.APP_FILES_DIR}/images/favicon.png",
                                    "fs_path": "ui/favicon.png",
                                    "content_type": "images/png"
                                }
                            ]
                        },
                        "user_transformer_configs": [
                            {
                                "matchers": [
                                    "exact match origin local"
                                ],
                                "actions": [
                                    "action add role authp/user",
                                    "ui link \"User Profile\" /auth/profile/ icon \"las la-cog\""
                                ]
                            }
                        ],
                        "cookie_config": {
                            "guess_domain_enabled": true,
                            "session_id_cookie_name": "AUTHP_SESSION_ID",
                            "referer_cookie_name": "AUTHP_REDIRECT_URL",
                            "sandbox_id_cookie_name": "AUTHP_SANDBOX_ID",
                            "identity_token_cookie_name": "AUTHP_ID_TOKEN",
                            "access_token_cookie_name": "AUTHP_ACCESS_TOKEN",
                            "refresh_token_cookie_name": "AUTHP_REFRESH_TOKEN",
                            "cookie_name_prefix": "AUTHP"
                        },
                        "identity_stores": [
                            "localdb"
                        ],
                        "token_validator_options": {},
                        "raw_crypto_key_store_config": [
                            "crypto default token lifetime 3600",
                            "crypto key sign-verify {env.JWT_SHARED_KEY}"
                        ],
                        "crypto_key_store_config": {
                            "token_lifetime": 3600,
                            "raw_key_configs": [
                                "crypto key sign-verify {env.JWT_SHARED_KEY}"
                            ],
                            "auto_generate_tag": "default",
                            "auto_generate_algo": "ES512"
                        },
                        "token_grantor_options": {},
                        "portal_admin_roles": {
                            "authp/admin": true
                        },
                        "portal_user_roles": {
                            "authp/user": true
                        },
                        "portal_guest_roles": {
                            "authp/guest": true
                        },
                        "api": {
                            "profile_enabled": true
                        }
                    }
                ],
                "identity_stores": [
                    {
                        "name": "localdb",
                        "kind": "local",
                        "params": {
                            "path": "assets/config/users.json",
                            "realm": "local",
                            "users": [
                                {
                                    "email_address": "{env.USERS_ADMIN_EMAIL}",
                                    "name": "{env.USERS_ADMIN_NAME}",
                                    "password": "{env.USERS_ADMIN_SECRET}",
                                    "password_overwrite_enabled": true,
                                    "roles": [
                                        "authp/admin",
                                        "authp/user"
                                    ],
                                    "username": "{env.USERS_ADMIN_USERNAME}"
                                }
                            ]
                        }
                    }
                ]
            }
        }
    }
}