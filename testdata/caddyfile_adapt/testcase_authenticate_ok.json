{
	"apps": {
		"http": {
			"servers": {
				"srv0": {
					"listen": [
						":8443"
					],
					"routes": [
						{
							"handle": [
								{
									"handler": "static_response",
									"headers": {
										"Location": [
											"https://{http.request.hostport}/auth/"
										]
									},
									"status_code": 302
								}
							]
						},
						{
							"match": [
								{
									"path": [
										"/auth*"
									]
								}
							],
							"handle": [
								{
									"handler": "subroute",
									"routes": [
										{
											"handle": [
												{
													"handler": "authenticator",
													"portal_name": "myportal",
													"route_matcher": "*"
												}
											]
										}
									]
								}
							]
						}
					]
				}
			}
		}
	}
}