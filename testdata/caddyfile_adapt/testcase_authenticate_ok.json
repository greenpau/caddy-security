{
	"apps": {
		"http": {
			"servers": {
				"srv0": {
					"listen": [
						":8443"
					],
					"routes": [
						{
							"match": [
								{
									"path": [
										"/auth*"
									]
								}
							],
							"handle": [
								{
									"handler": "subroute",
									"routes": [
										{
											"handle": [
												{
													"handler": "subroute",
													"routes": [
														{
															"handle": [
																{
																	"handler": "authenticator",
																	"portal_name": "myportal",
																	"route_matcher": "*"
																}
															]
														}
													]
												}
											],
											"match": [
												{
													"path": [
														"*"
													]
												}
											]
										}
									]
								}
							]
						}
					]
				}
			}
		}
	}
}