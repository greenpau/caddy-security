{
	"apps": {
		"http": {
			"servers": {
				"srv0": {
					"listen": [
						":8443"
					],
					"routes": [
						{
							"match": [
								{
									"path": [
										"/api/*"
									]
								}
							],
							"handle": [
								{
									"handler": "subroute",
									"routes": [
										{
											"handle": [
												{
													"handler": "authentication",
													"providers": {
														"authorizer": {
															"gatekeeper_name": "api_access_policy",
															"route_matcher": "*"
														}
													}
												},
												{
													"body": "api access granted to {http.auth.user.id} in {http.auth.user.realm}",
													"handler": "static_response",
													"status_code": 200
												}
											]
										}
									]
								}
							]
						}
					]
				}
			}
		}
	}
}