{
	security {
		credentials root@localhost {
			username root
			password {env.FOO_PASSWORD}
		}

		credentials {env.FOO_USERNAME} {
			username foo
			password {env.FOO_PASSWORD}
			domain {env.FOO_DOMAIN}
		}

		local identity store local assets/config/users.json
		authentication portal myportal {
			crypto key sign-verify {env.JWT_SHARED_KEY}
			enable identity store localdb
			cookie domain {env.GLOBAL_APP_DOMAIN}
		}
	}
}

:443 {
	authenticate with myportal
}
