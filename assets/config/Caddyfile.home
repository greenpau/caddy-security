		# local identity store userpool2 {
		# 	realm userpool2.localdomain
		# 	icon "USERPOOL2" "las la-shield-alt la-2x" "white" "#fc6d26" priority 80
		# 	path assets/config/userpool2.json
		# 	user webadmin {
